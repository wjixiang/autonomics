# =============================================================================
# agentik workspace — environment variables
# Copy this file to .env and fill in values as needed.
# =============================================================================

# ── LLM Provider API Keys ────────────────────────────────────────────────────
# Required when using the corresponding LLM provider.

MIMO_API_KEY=                          # Xiaomi Mimo provider
SENSENOVA_API_KEY=                     # SenseNova provider
MINIMAX_API_KEY=                       # MiniMax provider
DEEPSEEK_API_KEY=                      # DeepSeek provider
ZAI_API_KEY=                           # Z.ai provider

# ── Custom Gateway (integration tests) ─────────────────────────────────────────
# Optional — defaults are provided for test code.

CUSTOM_BASE_URL=https://your-custom-gateway.example.com/v1/anthropic
CUSTOM_MODEL_NAME=claude-3-5-sonnet-latest
CUSTOM_BEARER_TOKEN=

# ── Iceberg Data Lake ─────────────────────────────────────────────────────────
# Required by the datalake crate.

ICEBERG_REST_URI=                      # e.g. http://localhost:8181
ICEBERG_S3_ACCESS_KEY_ID=
ICEBERG_S3_SECRET_ACCESS_KEY=

# ── OpenGWAS API ──────────────────────────────────────────────────────────────
# Bearer token for the OpenGWAS / GWAS Catalog API.
# Panics if neither this nor a CLI argument is provided to OpengwasClient.

OPENGWAS_TOKEN=

# ── NCBI E-utilities ──────────────────────────────────────────────────────────
# Optional — defaults are provided.

EUTILS_TOOL=agentik                    # identifies the calling application
EUTILS_EMAIL=agentik@localhost         # contact email (NCBI policy)
EUTILS_API_KEY=                        # optional; raises rate limit 3→10 req/s

# ── Application Paths ─────────────────────────────────────────────────────────
# Optional — each has a sensible default.

PHLOEM_CONFIG=phloem.json              # phloem-server config file path
BIBLIOGRAPHY_SEARCH_DIR=/mnt/disk1/project/bibliography-search
KMS_DB_PATH=data/kms_sqlite.db         # KMS SQLite database path
KMS_LOG_PATH=data/tui.log              # KMS TUI log file path
DOWNLOAD_DIR_PATH=data/download        # Download data storage directory

# ── Logging ──────────────────────────────────────────────────────────────────
# Controls tracing log levels. Required by dendrite/kms_tui (uses from_default_env).
# Optional for phloem-server and phloem-tui (use try_from_default_env with fallback).

RUST_LOG=info                          # e.g. phloem_server=debug,tower_http=debug
